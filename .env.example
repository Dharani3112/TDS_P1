# Environment variables template
# Copy this file to .env and fill in your actual values

# AI Pipe Configuration (Primary)
AIPIPE_TOKEN=your_aipipe_token_here
AIPIPE_BASE_URL=https://aipipe.org/api/v1

# OpenAI Configuration (Legacy - now using AI Pipe)
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=tds_virtual_ta

# Scraping Configuration
COURSE_URL=https://tds.s-anand.net/
DISCOURSE_URL=https://discourse.onlinedegree.iitm.ac.in/

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Scraping Limits
MAX_PAGES_PER_SITE=100
REQUEST_DELAY=1.0

# LLM Configuration
DEFAULT_MODEL=gpt-4o-mini
MAX_TOKENS=1000
TEMPERATURE=0.1
